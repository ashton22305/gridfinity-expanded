{
  "name": "gridfinity-expanded",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "classify:changes": "node scripts/classify-changes.mjs",
    "check:manifold": "esbuild scripts/check-manifold.ts --bundle --platform=node --format=esm --external:manifold-3d --outfile=node_modules/.cache/check-manifold.mjs --log-level=error && node node_modules/.cache/check-manifold.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@babylonjs/core": "^9.14.0",
    "@babylonjs/loaders": "^9.14.0",
    "@jscad/3mf-serializer": "^2.1.17",
    "@jscad/modeling": "^2.13.0",
    "@jscad/stl-serializer": "^2.1.23",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "manifold-3d": "^3.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
